{
  "name": "@tauri-plugin/visual-editor-sdk",
  "version": "0.1.0",
  "description": "Framework-neutral metadata helpers for Visual Editor",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react-entry.d.ts",
      "import": "./dist/react-entry.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.7"
  }
}
