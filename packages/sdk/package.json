{
  "name": "@iamthamanic/visual-editor-sdk",
  "version": "0.1.1",
  "description": "Framework-neutral metadata helpers for Visual Editor",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react-entry.d.ts",
      "import": "./dist/react-entry.js"
    },
    "./overlay": {
      "types": "./dist/overlay/index.d.ts",
      "import": "./dist/overlay/index.js"
    },
    "./overlay.css": "./dist/overlay/overlay.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/overlay && cp src/overlay/overlay.css dist/overlay/overlay.css",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamthamanic/tauri-plugin-visual-editor.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@tauri-apps/api": ">=2",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@tauri-apps/api": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.7"
  }
}
