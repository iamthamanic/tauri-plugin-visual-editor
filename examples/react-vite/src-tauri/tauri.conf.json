{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Visual Editor Demo",
  "version": "0.1.0",
  "identifier": "com.tauri-plugin.visual-editor.demo",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Visual Editor Demo",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "visualEditor": {
      "enabled": true,
      "allow": true,
      "allowInProduction": false
    }
  }
}
